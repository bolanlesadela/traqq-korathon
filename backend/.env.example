# ─── SERVER ───────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ─── SUPABASE ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── JWT ──────────────────────────────────────────
JWT_ACCESS_SECRET=minimum-32-character-random-secret-here
JWT_REFRESH_SECRET=different-minimum-32-character-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── KORAPAY ──────────────────────────────────────
KORAPAY_SECRET_KEY=your-korapay-secret-key
KORAPAY_PUBLIC_KEY=your-korapay-public-key
KORAPAY_WEBHOOK_SECRET=your-korapay-webhook-secret

# ─── RATE LIMITING ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=10
RATE_LIMIT_MAX_GENERAL=100
